{
  "name": "qrdonate",
  "version": "0.1.0",
  "description": "Reusable Toss transfer QR donation API and embeddable page.",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "test": "tsx --test src/**/*.test.ts",
    "typecheck:vercel": "tsc -p tsconfig.vercel.json"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
